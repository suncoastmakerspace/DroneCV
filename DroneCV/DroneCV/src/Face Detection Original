#Importing the modules
import cv2

#Loading the Hoar Cascade Model
face_cascade = cv2.CascadeClassifier(cv2.data.haarcascades +
"haarcascade_frontalface_default.xml")

#Starting the camera
video = cv2.VideoCapture(0)

#Assign each individual a number
index = 1
tracked_faces = {}

#Running the frame
while True:
    ret, frame = video.read()
    if ret == False:
        break

    #Convert to grayscale
    gray_scale = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
    
    #Face detection
    faces = face_cascade.detectMultiScale(gray_scale, scaleFactor=1.3,
minNeighbors=5)
    current_faces = []

    #Draw rectangle around face
    for(x, y, w, h) in faces:
        #center coordinates of the face
        center_x = (x + w) // 2
        center_y = (y + h) // 2
        matched_id = None

        # Compare with tracked faces from previous frame(s)
        for face_id, (px, py) in tracked_faces.items():
            distance = ((center_x - px)**2 + (center_y - py)**2) ** 0.5
            if distance < 50:
                matched_id = face_id
                break
            if matched_id is None:
                matched_id = index
                index += 1
            cv2.rectangle(frame, (x, y), (x + w, y + h), (0, 255, 0), 2)
            #Label the face with the index
            cv2.putText(frame, str(index), (x, y - 10),
            cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0, 255, 0), 2)

    current_faces.append((matched_id, center_x, center_y))
    tracked_faces = {face_id: (cx, cy) for face_id, cx, cy in
current_faces}
    cv2.imshow("Face Detection"
, frame)
    if cv2.waitKey(1) == ord(' '):
        break

video.release()
cv2.destroyAllWindow
